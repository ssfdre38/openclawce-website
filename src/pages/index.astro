---
import LandingLayout from '@/layouts/LandingLayout.astro';
import { Hero } from '@/components/hero';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import SocialProof from '@/components/ui/marketing/SocialProof/SocialProof.astro';
import { TerminalDemo } from '@/components/ui/marketing/TerminalDemo';
import TechStack from '@/components/landing/TechStack.astro';
import FeatureTabs from '@/components/landing/FeatureTabs.tsx';
import Credibility from '@/components/landing/Credibility.astro';
import CTA from '@/components/landing/CTA.astro';
---

<LandingLayout
  title="OpenClaw CE - Open Source AI Agent Platform"
  description="Build powerful AI agents with OpenClaw Community Edition. Open source, self-hosted, and built for developers who want full control over their AI automation."
>
  <Hero layout="split" size="lg" showGrid showBlob blobPosition="right">
    <Badge slot="badge" pill pulse>Community Edition - Open Source</Badge>

    <h1 slot="title">
      Your Personal AI Assistant<br />
      <span class="text-brand-500">Runs Everywhere</span>
    </h1>

    <p slot="description">
      OpenClaw CE combines the best AI models (OpenAI, Claude, Gemini, Ollama) with powerful tools (GitHub, web browsing, image generation) in a beautiful desktop app and CLI. Free, open-source, and runs entirely on your machine.
    </p>

    <Fragment slot="actions">
      <Button size="lg" href="/downloads">
        Get Started
        <Icon name="arrow-right" size="sm" />
      </Button>
      <Button
        size="lg"
        variant="outline"
        href="https://github.com/ssfdre38/openclaw-community-edition"
        target="_blank"
      >
        <Icon name="github" size="sm" />
        View on GitHub
      </Button>
    </Fragment>

    <TerminalDemo slot="aside" client:load />

    <SocialProof
      class="mt-[var(--space-stack-lg)]"
      text="Trusted by developers worldwide"
      avatars={[
        'https://i.pravatar.cc/150?img=12',
        'https://i.pravatar.cc/150?img=33',
        'https://i.pravatar.cc/150?img=47',
      ]}
    />
  </Hero>

  <TechStack />
  <FeatureTabs client:visible />
  <Credibility />
  <CTA />
</LandingLayout>
