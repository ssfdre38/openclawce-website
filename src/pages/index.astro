---
import LandingLayout from '@/layouts/LandingLayout.astro';
import { Hero } from '@/components/hero';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import SocialProof from '@/components/ui/marketing/SocialProof/SocialProof.astro';
import { TerminalDemo } from '@/components/ui/marketing/TerminalDemo';
import TechStack from '@/components/landing/TechStack.astro';
import FeatureTabs from '@/components/landing/FeatureTabs.tsx';
import Credibility from '@/components/landing/Credibility.astro';
import CTA from '@/components/landing/CTA.astro';
---

<LandingLayout
  title="OpenClaw CE - Open Source AI Agent Platform"
  description="Build powerful AI agents with OpenClaw Community Edition. Open source, self-hosted, and built for developers who want full control over their AI automation."
>
  <Hero layout="split" size="lg" showGrid showBlob blobPosition="right">
    <Badge slot="badge" pill pulse>Community Edition - Open Source</Badge>

    <h1 slot="title">
      Your Personal AI Assistant<br />
      <span class="text-brand-500">Runs Everywhere</span>
    </h1>

    <p slot="description">
      OpenClaw CE combines the best AI models (OpenAI, Claude, Gemini, Ollama) with powerful tools (GitHub, web browsing, image generation) in a beautiful desktop app and CLI. Free, open-source, and runs entirely on your machine.
    </p>

    <div slot="install-command" class="mt-6 p-4 bg-neutral-900 rounded-lg border border-neutral-800 max-w-xl">
      <div class="flex items-center gap-2 mb-2">
        <Icon name="terminal" size="sm" class="text-emerald-400" />
        <span class="text-xs text-neutral-400 font-semibold">INSTALL WITH NPM</span>
      </div>
      <div class="flex items-center justify-between gap-3">
        <code class="text-sm text-emerald-400 font-mono">npm install -g openclaw-ce</code>
        <button
          onclick="navigator.clipboard.writeText('npm install -g openclaw-ce'); this.innerHTML = '✓ Copied'; setTimeout(() => this.innerHTML = '<svg class=&quot;w-4 h-4&quot; fill=&quot;none&quot; stroke=&quot;currentColor&quot; viewBox=&quot;0 0 24 24&quot;><path stroke-linecap=&quot;round&quot; stroke-linejoin=&quot;round&quot; stroke-width=&quot;2&quot; d=&quot;M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z&quot;></path></svg>', 2000)"
          class="px-3 py-1.5 bg-neutral-800 hover:bg-neutral-700 rounded text-xs text-neutral-300 transition-colors flex items-center gap-1"
          aria-label="Copy install command"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
          </svg>
        </button>
      </div>
      <p class="text-xs text-neutral-500 mt-2">
        Or view <a href="/downloads" class="text-emerald-400 hover:text-emerald-300 underline">other installation methods</a>
      </p>
    </div>

    <Fragment slot="actions">
      <Button size="lg" href="/downloads">
        Get Started
        <Icon name="arrow-right" size="sm" />
      </Button>
      <Button
        size="lg"
        variant="outline"
        href="https://github.com/ssfdre38/openclaw-community-edition"
        target="_blank"
      >
        <Icon name="github" size="sm" />
        View on GitHub
      </Button>
    </Fragment>

    <TerminalDemo slot="aside" client:load />

    <SocialProof
      class="mt-[var(--space-stack-lg)]"
      text="Trusted by developers worldwide"
      avatars={[
        'https://i.pravatar.cc/150?img=12',
        'https://i.pravatar.cc/150?img=33',
        'https://i.pravatar.cc/150?img=47',
      ]}
    />
  </Hero>

  <TechStack />
  <FeatureTabs client:visible />
  <Credibility />
  <CTA />
</LandingLayout>
