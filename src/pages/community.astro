---
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/ui/layout/Container/Container.astro';
import Section from '@/components/ui/layout/Section/Section.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Button from '@/components/ui/form/Button/Button.astro';
---

<PageLayout
  title="Community - OpenClaw CE"
  description="Join the OpenClaw Community Edition community - contribute, get support, and connect with other developers"
>
  <Container>
    <Section>
      <div class="text-center max-w-3xl mx-auto mb-16">
        <Badge pill class="mb-4">Community</Badge>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          Join the <span class="text-brand-500">OpenClaw</span> Community
        </h1>
        <p class="text-lg text-neutral-600 dark:text-neutral-400">
          Connect with developers building AI agents, get support, share your projects, and contribute to the future of OpenClaw CE.
        </p>
      </div>

      <!-- Community Channels -->
      <div class="grid md:grid-cols-2 gap-6 mb-16">
        <Card class="hover:shadow-lg transition-shadow">
          <a href="https://github.com/ssfdre38/openclaw-community-edition" target="_blank" class="block p-8">
            <div class="flex items-start gap-4">
              <div class="p-3 rounded-lg bg-neutral-900 text-white">
                <Icon name="github" size="xl" />
              </div>
              <div class="flex-1">
                <h3 class="text-xl font-bold mb-2">GitHub</h3>
                <p class="text-neutral-600 dark:text-neutral-400 mb-3">
                  Star the repo, report issues, contribute code, and track development
                </p>
                <Badge>Community Edition</Badge>
              </div>
            </div>
          </a>
        </Card>

        <Card class="hover:shadow-lg transition-shadow">
          <a href="https://discord.gg/openclawce" target="_blank" class="block p-8">
            <div class="flex items-start gap-4">
              <div class="p-3 rounded-lg bg-indigo-500 text-white">
                <Icon name="message-circle" size="xl" />
              </div>
              <div class="flex-1">
                <h3 class="text-xl font-bold mb-2">Discord</h3>
                <p class="text-neutral-600 dark:text-neutral-400 mb-3">
                  Real-time chat, support, and discussions with the community
                </p>
                <Badge>500+ members</Badge>
              </div>
            </div>
          </a>
        </Card>

        <Card class="hover:shadow-lg transition-shadow">
          <a href="https://github.com/ssfdre38/openclaw-community-edition/discussions" target="_blank" class="block p-8">
            <div class="flex items-start gap-4">
              <div class="p-3 rounded-lg bg-green-500 text-white">
                <Icon name="users" size="xl" />
              </div>
              <div class="flex-1">
                <h3 class="text-xl font-bold mb-2">Discussions</h3>
                <p class="text-neutral-600 dark:text-neutral-400 mb-3">
                  Ask questions, share ideas, and discuss features on GitHub Discussions
                </p>
                <Badge>Active</Badge>
              </div>
            </div>
          </a>
        </Card>

        <Card class="hover:shadow-lg transition-shadow">
          <a href="https://twitter.com/openclawce" target="_blank" class="block p-8">
            <div class="flex items-start gap-4">
              <div class="p-3 rounded-lg bg-blue-400 text-white">
                <Icon name="twitter" size="xl" />
              </div>
              <div class="flex-1">
                <h3 class="text-xl font-bold mb-2">Twitter/X</h3>
                <p class="text-neutral-600 dark:text-neutral-400 mb-3">
                  Follow for updates, announcements, and community highlights
                </p>
                <Badge>Follow us</Badge>
              </div>
            </div>
          </a>
        </Card>
      </div>

      <!-- Contributing -->
      <Card class="mb-16">
        <div class="p-8">
          <div class="flex items-start gap-4 mb-6">
            <div class="p-3 rounded-lg bg-brand-500 text-white">
              <Icon name="git-pull-request" size="xl" />
            </div>
            <div>
              <h2 class="text-3xl font-bold mb-2">Contributing</h2>
              <p class="text-neutral-600 dark:text-neutral-400">
                OpenClaw CE is open source and we welcome contributions from the community!
              </p>
            </div>
          </div>

          <div class="grid md:grid-cols-3 gap-6">
            <div>
              <h4 class="font-semibold mb-3 flex items-center gap-2">
                <Icon name="code" size="sm" class="text-brand-500" />
                Code Contributions
              </h4>
              <ul class="space-y-2 text-neutral-600 dark:text-neutral-400 text-sm">
                <li>• Fix bugs and issues</li>
                <li>• Add new features</li>
                <li>• Improve performance</li>
                <li>• Write tests</li>
              </ul>
            </div>
            <div>
              <h4 class="font-semibold mb-3 flex items-center gap-2">
                <Icon name="book-open" size="sm" class="text-brand-500" />
                Documentation
              </h4>
              <ul class="space-y-2 text-neutral-600 dark:text-neutral-400 text-sm">
                <li>• Improve docs</li>
                <li>• Write tutorials</li>
                <li>• Add examples</li>
                <li>• Fix typos</li>
              </ul>
            </div>
            <div>
              <h4 class="font-semibold mb-3 flex items-center gap-2">
                <Icon name="users" size="sm" class="text-brand-500" />
                Community
              </h4>
              <ul class="space-y-2 text-neutral-600 dark:text-neutral-400 text-sm">
                <li>• Answer questions</li>
                <li>• Share projects</li>
                <li>• Test releases</li>
                <li>• Report bugs</li>
              </ul>
            </div>
          </div>

          <div class="mt-6 pt-6 border-t border-neutral-200 dark:border-neutral-700">
            <Button href="https://github.com/ssfdre38/openclaw-community-edition/blob/discord-fix/CONTRIBUTING.md" target="_blank">
              <Icon name="book-open" size="sm" />
              Read Contributing Guide
            </Button>
          </div>
        </div>
      </Card>

      <!-- Community Guidelines -->
      <Card class="mb-16">
        <div class="p-8">
          <h2 class="text-3xl font-bold mb-6 flex items-center gap-2">
            <Icon name="heart" size="lg" class="text-red-500" />
            Community Guidelines
          </h2>
          <div class="grid md:grid-cols-2 gap-8">
            <div>
              <h4 class="font-semibold mb-3 text-green-600 dark:text-green-400 flex items-center gap-2">
                <Icon name="check-circle" size="sm" />
                Do
              </h4>
              <ul class="space-y-2 text-neutral-600 dark:text-neutral-400">
                <li>✅ Be respectful and inclusive</li>
                <li>✅ Help others when you can</li>
                <li>✅ Share constructive feedback</li>
                <li>✅ Follow our code of conduct</li>
              </ul>
            </div>
            <div>
              <h4 class="font-semibold mb-3 text-red-600 dark:text-red-400 flex items-center gap-2">
                <Icon name="x-circle" size="sm" />
                Don't
              </h4>
              <ul class="space-y-2 text-neutral-600 dark:text-neutral-400">
                <li>❌ Be rude or disrespectful</li>
                <li>❌ Spam or self-promote excessively</li>
                <li>❌ Share sensitive information</li>
                <li>❌ Violate our code of conduct</li>
              </ul>
            </div>
          </div>
        </div>
      </Card>

      <!-- Support -->
      <div class="text-center p-8 bg-gradient-to-r from-brand-500/10 to-brand-600/10 rounded-2xl">
        <h2 class="text-3xl font-bold mb-4">Get Support</h2>
        <p class="text-lg text-neutral-600 dark:text-neutral-400 mb-6 max-w-2xl mx-auto">
          Need help with OpenClaw CE? Our community is here to support you.
        </p>
        <div class="flex gap-4 justify-center flex-wrap">
          <Button href="/docs" variant="outline">
            <Icon name="book-open" size="sm" />
            Read Docs
          </Button>
          <Button href="https://github.com/ssfdre38/openclaw-community-edition/discussions" target="_blank" variant="outline">
            <Icon name="message-circle" size="sm" />
            Ask Question
          </Button>
          <Button href="https://github.com/ssfdre38/openclaw-community-edition/issues/new" target="_blank" variant="outline">
            <Icon name="bug" size="sm" />
            Report Bug
          </Button>
        </div>
      </div>
    </Section>
  </Container>
</PageLayout>
