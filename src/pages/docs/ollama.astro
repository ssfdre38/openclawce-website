---
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/ui/layout/Container/Container.astro';
import Section from '@/components/ui/layout/Section/Section.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
---

<PageLayout
  title="Ollama Integration - OpenClaw CE"
  description="Use local AI models with OpenClaw CE via Ollama"
>
  <Container>
    <Section>
      <div class="max-w-4xl mx-auto">
        <div class="mb-8">
          <Badge pill class="mb-4">AI Providers</Badge>
          <h1 class="text-4xl font-bold mb-4">Ollama Integration</h1>
          <p class="text-lg text-neutral-600 dark:text-neutral-400">
            Run powerful local AI models completely offline with Ollama integration.
          </p>
        </div>

        <Card class="mb-8">
          <div class="p-8">
            <h2 class="text-2xl font-bold mb-6">Why Use Ollama?</h2>
            
            <ul class="space-y-3 text-neutral-600 dark:text-neutral-400">
              <li class="flex gap-3">
                <span class="text-green-500">✓</span>
                <span><strong>100% Private:</strong> All processing happens locally on your machine</span>
              </li>
              <li class="flex gap-3">
                <span class="text-green-500">✓</span>
                <span><strong>No API Costs:</strong> Run unlimited conversations without usage fees</span>
              </li>
              <li class="flex gap-3">
                <span class="text-green-500">✓</span>
                <span><strong>Offline Capable:</strong> Works without internet connection</span>
              </li>
              <li class="flex gap-3">
                <span class="text-green-500">✓</span>
                <span><strong>Fast:</strong> Low latency responses on good hardware</span>
              </li>
              <li class="flex gap-3">
                <span class="text-green-500">✓</span>
                <span><strong>Many Models:</strong> Llama, Mistral, Gemma, Qwen, and more</span>
              </li>
            </ul>
          </div>
        </Card>

        <Card class="mb-8">
          <div class="p-8">
            <h2 class="text-2xl font-bold mb-6">Installation</h2>
            
            <h3 class="text-xl font-semibold mb-3">1. Install Ollama</h3>
            <div class="space-y-4 mb-6">
              <div>
                <p class="font-semibold mb-2">macOS / Linux:</p>
                <div class="bg-neutral-900 text-neutral-100 p-4 rounded-lg font-mono text-sm">
                  <code>curl -fsSL https://ollama.com/install.sh | sh</code>
                </div>
              </div>
              <div>
                <p class="font-semibold mb-2">Windows:</p>
                <div class="bg-neutral-900 text-neutral-100 p-4 rounded-lg font-mono text-sm">
                  <code># Download from https://ollama.com/download/windows</code>
                </div>
              </div>
            </div>

            <h3 class="text-xl font-semibold mb-3">2. Pull a Model</h3>
            <div class="bg-neutral-900 text-neutral-100 p-4 rounded-lg font-mono text-sm overflow-x-auto mb-4">
              <code>
                # Recommended: Llama 3.2 (3B - fast, good quality)<br/>
                ollama pull llama3.2<br/><br/>
                # Or try other models:<br/>
                ollama pull mistral       # 7B - balanced<br/>
                ollama pull gemma2:2b    # 2B - lightweight<br/>
                ollama pull qwen2.5:7b   # 7B - coding focused
              </code>
            </div>

            <h3 class="text-xl font-semibold mb-3">3. Verify Ollama is Running</h3>
            <div class="bg-neutral-900 text-neutral-100 p-4 rounded-lg font-mono text-sm overflow-x-auto">
              <code>
                curl http://localhost:11434/api/version
              </code>
            </div>
          </div>
        </Card>

        <Card class="mb-8">
          <div class="p-8">
            <h2 class="text-2xl font-bold mb-6">Configuration</h2>
            
            <p class="text-neutral-600 dark:text-neutral-400 mb-4">
              Add to your <code class="bg-neutral-100 dark:bg-neutral-800 px-2 py-1 rounded">config.yaml</code>:
            </p>
            <div class="bg-neutral-900 text-neutral-100 p-4 rounded-lg font-mono text-sm overflow-x-auto mb-6">
              <code>
                provider: ollama<br/><br/>
                ollama:<br/>
                &nbsp;&nbsp;host: http://localhost:11434<br/>
                &nbsp;&nbsp;model: llama3.2<br/>
                &nbsp;&nbsp;# Optional settings<br/>
                &nbsp;&nbsp;temperature: 0.7<br/>
                &nbsp;&nbsp;top_p: 0.9<br/>
                &nbsp;&nbsp;num_ctx: 8192  # Context window size
              </code>
            </div>

            <h3 class="text-xl font-semibold mb-3">Model Recommendations</h3>
            <div class="space-y-4">
              <div class="p-4 border border-neutral-200 dark:border-neutral-700 rounded-lg">
                <h4 class="font-semibold mb-2">🚀 Fast & Efficient</h4>
                <p class="text-sm text-neutral-600 dark:text-neutral-400 mb-2">
                  <code class="bg-neutral-100 dark:bg-neutral-800 px-2 py-1 rounded">llama3.2</code> (3B) - Best balance
                </p>
                <p class="text-sm text-neutral-600 dark:text-neutral-400">
                  Great for most tasks, runs smoothly on 8GB RAM
                </p>
              </div>

              <div class="p-4 border border-neutral-200 dark:border-neutral-700 rounded-lg">
                <h4 class="font-semibold mb-2">💪 High Quality</h4>
                <p class="text-sm text-neutral-600 dark:text-neutral-400 mb-2">
                  <code class="bg-neutral-100 dark:bg-neutral-800 px-2 py-1 rounded">mistral</code> (7B) - Better reasoning
                </p>
                <p class="text-sm text-neutral-600 dark:text-neutral-400">
                  More capable, needs 16GB+ RAM recommended
                </p>
              </div>

              <div class="p-4 border border-neutral-200 dark:border-neutral-700 rounded-lg">
                <h4 class="font-semibold mb-2">💻 Code-Focused</h4>
                <p class="text-sm text-neutral-600 dark:text-neutral-400 mb-2">
                  <code class="bg-neutral-100 dark:bg-neutral-800 px-2 py-1 rounded">qwen2.5-coder:7b</code> - Best for coding
                </p>
                <p class="text-sm text-neutral-600 dark:text-neutral-400">
                  Optimized for code generation and analysis
                </p>
              </div>
            </div>
          </div>
        </Card>

        <Card class="mb-8">
          <div class="p-8">
            <h2 class="text-2xl font-bold mb-6">Advanced Features</h2>
            
            <h3 class="text-xl font-semibold mb-3">Multi-Tier Model Setup</h3>
            <p class="text-neutral-600 dark:text-neutral-400 mb-4">
              OpenClaw CE supports using different models for different complexity levels:
            </p>
            <div class="bg-neutral-900 text-neutral-100 p-4 rounded-lg font-mono text-sm overflow-x-auto mb-6">
              <code>
                ollama:<br/>
                &nbsp;&nbsp;host: http://localhost:11434<br/>
                &nbsp;&nbsp;# Fast model for simple tasks<br/>
                &nbsp;&nbsp;model_fast: llama3.2<br/>
                &nbsp;&nbsp;# Balanced model for medium tasks<br/>
                &nbsp;&nbsp;model_medium: mistral<br/>
                &nbsp;&nbsp;# Powerful model for complex tasks<br/>
                &nbsp;&nbsp;model_complex: qwen2.5:14b<br/>
                &nbsp;&nbsp;# Enable automatic model selection<br/>
                &nbsp;&nbsp;auto_select: true
              </code>
            </div>

            <h3 class="text-xl font-semibold mb-3">Custom System Prompts</h3>
            <div class="bg-neutral-900 text-neutral-100 p-4 rounded-lg font-mono text-sm overflow-x-auto">
              <code>
                ollama:<br/>
                &nbsp;&nbsp;host: http://localhost:11434<br/>
                &nbsp;&nbsp;model: llama3.2<br/>
                &nbsp;&nbsp;system_prompt: |<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;You are a helpful AI assistant running locally.<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;You have access to various tools and can help<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;with tasks like coding, writing, and research.
              </code>
            </div>
          </div>
        </Card>

        <Card>
          <div class="p-8">
            <h2 class="text-2xl font-bold mb-6">Performance Tips</h2>
            
            <ul class="space-y-3 text-neutral-600 dark:text-neutral-400">
              <li class="flex gap-3">
                <span class="text-brand-500 font-bold">→</span>
                <span><strong>GPU Acceleration:</strong> Ollama automatically uses your GPU if available (NVIDIA, AMD, or Apple Silicon)</span>
              </li>
              <li class="flex gap-3">
                <span class="text-brand-500 font-bold">→</span>
                <span><strong>RAM Usage:</strong> Models stay loaded in memory. 3B models need ~2-3GB, 7B models need ~4-6GB</span>
              </li>
              <li class="flex gap-3">
                <span class="text-brand-500 font-bold">→</span>
                <span><strong>First Response:</strong> Initial response is slower (model loading), subsequent responses are fast</span>
              </li>
              <li class="flex gap-3">
                <span class="text-brand-500 font-bold">→</span>
                <span><strong>Quantization:</strong> Use quantized models (Q4, Q5) for better performance with minimal quality loss</span>
              </li>
              <li class="flex gap-3">
                <span class="text-brand-500 font-bold">→</span>
                <span><strong>Context Window:</strong> Reduce <code class="bg-neutral-100 dark:bg-neutral-800 px-1">num_ctx</code> if you hit memory limits</span>
              </li>
            </ul>
          </div>
        </Card>
      </div>
    </Section>
  </Container>
</PageLayout>
