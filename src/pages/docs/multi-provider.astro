---
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/ui/layout/Container/Container.astro';
import Section from '@/components/ui/layout/Section/Section.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
---

<PageLayout
  title="Multi-Provider Setup - OpenClaw CE"
  description="Configure multiple AI providers for flexibility and reliability"
>
  <Container>
    <Section>
      <div class="max-w-4xl mx-auto">
        <div class="mb-8">
          <Badge pill class="mb-4">Configuration</Badge>
          <h1 class="text-4xl font-bold mb-4">Multi-Provider Configuration</h1>
          <p class="text-lg text-neutral-600 dark:text-neutral-400">
            Use OpenAI, Anthropic, Google, and Ollama together - switch models on demand or use automatic routing
          </p>
        </div>

        <Card class="mb-8">
          <div class="p-8">
            <h2 class="text-2xl font-bold mb-6">Why Multiple Providers?</h2>
            
            <ul class="space-y-3 text-neutral-600 dark:text-neutral-400">
              <li class="flex gap-3">
                <span class="text-green-500">✓</span>
                <span><strong>Choose the best model:</strong> GPT-4 for coding, Claude for writing, Gemini for multimodal</span>
              </li>
              <li class="flex gap-3">
                <span class="text-green-500">✓</span>
                <span><strong>Fallback protection:</strong> If one provider is down, automatically use another</span>
              </li>
              <li class="flex gap-3">
                <span class="text-green-500">✓</span>
                <span><strong>Cost optimization:</strong> Use cheaper models for simple tasks, premium models for complex ones</span>
              </li>
              <li class="flex gap-3">
                <span class="text-green-500">✓</span>
                <span><strong>Local + Cloud:</strong> Combine free local Ollama with cloud providers</span>
              </li>
              <li class="flex gap-3">
                <span class="text-green-500">✓</span>
                <span><strong>Privacy control:</strong> Keep sensitive work on local models, use cloud for general tasks</span>
              </li>
            </ul>
          </div>
        </Card>

        <Card class="mb-8">
          <div class="p-8">
            <h2 class="text-2xl font-bold mb-6">Complete Multi-Provider Setup</h2>
            
            <p class="text-neutral-600 dark:text-neutral-400 mb-4">
              Add all providers to <code class="bg-neutral-100 dark:bg-neutral-800 px-2 py-1 rounded">~/.openclaw/config.yaml</code>:
            </p>

            <div class="bg-neutral-900 text-neutral-100 p-4 rounded-lg font-mono text-sm overflow-x-auto">
              <code>
                providers:<br/>
                &nbsp;&nbsp;# OpenAI - Best for coding, reasoning<br/>
                &nbsp;&nbsp;- name: openai<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;type: openai<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;api_key: sk-your-openai-key<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;models:<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- gpt-4-turbo-preview<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- gpt-4<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- gpt-3.5-turbo<br/><br/>
                &nbsp;&nbsp;# Anthropic - Best for writing, analysis<br/>
                &nbsp;&nbsp;- name: anthropic<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;type: anthropic<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;api_key: sk-ant-your-anthropic-key<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;models:<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- claude-3-5-sonnet-20241022<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- claude-3-haiku-20240307<br/><br/>
                &nbsp;&nbsp;# Google Gemini - Best for multimodal<br/>
                &nbsp;&nbsp;- name: google<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;type: gemini<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;api_key: your-gemini-api-key<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;models:<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- gemini-pro<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- gemini-pro-vision<br/><br/>
                &nbsp;&nbsp;# Ollama - Free local models<br/>
                &nbsp;&nbsp;- name: ollama<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;type: ollama<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;endpoint: http://localhost:11434<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;models:<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- llama3.2:latest<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- qwen2.5-coder:7b<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- mistral:latest<br/><br/>
                # Default provider and model<br/>
                default_provider: openai<br/>
                default_model: gpt-4
              </code>
            </div>
          </div>
        </Card>

        <Card class="mb-8">
          <div class="p-8">
            <h2 class="text-2xl font-bold mb-6">Provider-Specific Configuration</h2>
            
            <h3 class="text-xl font-semibold mb-3">OpenAI</h3>
            <div class="bg-neutral-900 text-neutral-100 p-4 rounded-lg font-mono text-sm overflow-x-auto mb-6">
              <code>
                providers:<br/>
                &nbsp;&nbsp;- name: openai<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;type: openai<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;api_key: sk-your-key-here<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;organization: org-your-org-id  # Optional<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;base_url: https://api.openai.com/v1  # Optional, for proxies<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;models:<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- gpt-4-turbo-preview  # Latest GPT-4<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- gpt-4  # Stable GPT-4<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- gpt-3.5-turbo  # Fast and cheap
              </code>
            </div>

            <h3 class="text-xl font-semibold mb-3">Anthropic Claude</h3>
            <div class="bg-neutral-900 text-neutral-100 p-4 rounded-lg font-mono text-sm overflow-x-auto mb-6">
              <code>
                providers:<br/>
                &nbsp;&nbsp;- name: anthropic<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;type: anthropic<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;api_key: sk-ant-your-key-here<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;models:<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- claude-3-5-sonnet-20241022  # Best overall<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- claude-3-opus-20240229  # Most powerful<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- claude-3-haiku-20240307  # Fastest
              </code>
            </div>

            <h3 class="text-xl font-semibold mb-3">Google Gemini</h3>
            <div class="bg-neutral-900 text-neutral-100 p-4 rounded-lg font-mono text-sm overflow-x-auto mb-6">
              <code>
                providers:<br/>
                &nbsp;&nbsp;- name: google<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;type: gemini<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;api_key: your-gemini-key-here<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;models:<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- gemini-pro  # Text generation<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- gemini-pro-vision  # Image understanding
              </code>
            </div>

            <h3 class="text-xl font-semibold mb-3">Ollama (Local)</h3>
            <div class="bg-neutral-900 text-neutral-100 p-4 rounded-lg font-mono text-sm overflow-x-auto">
              <code>
                providers:<br/>
                &nbsp;&nbsp;- name: ollama<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;type: ollama<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;endpoint: http://localhost:11434<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;models:<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- llama3.2:latest  # Meta's Llama<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- qwen2.5-coder:7b  # Best for code<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- mistral:latest  # Good general model<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- phi3:latest  # Fast, low memory
              </code>
            </div>
          </div>
        </Card>

        <Card class="mb-8">
          <div class="p-8">
            <h2 class="text-2xl font-bold mb-6">Switching Models</h2>
            
            <h3 class="text-xl font-semibold mb-3">In the CLI</h3>
            <div class="space-y-4 mb-6">
              <div>
                <p class="text-sm font-semibold mb-2">Start with a specific model:</p>
                <div class="bg-neutral-900 text-neutral-100 p-3 rounded-lg font-mono text-sm">
                  <code>openclaw agent --message "Hello" --model claude-3-5-sonnet-20241022</code>
                </div>
              </div>
              <div>
                <p class="text-sm font-semibold mb-2">Use thinking mode:</p>
                <div class="bg-neutral-900 text-neutral-100 p-3 rounded-lg font-mono text-sm">
                  <code>You: /model gpt-4<br/>You: /model ollama:llama3.2:latest</code>
                </div>
              </div>
              <div>
                <p class="text-sm font-semibold mb-2">Run the gateway (web UI + relay):</p>
                <div class="bg-neutral-900 text-neutral-100 p-3 rounded-lg font-mono text-sm">
                  <code>openclaw gateway --port 18789</code>
                </div>
              </div>
            </div>

            <h3 class="text-xl font-semibold mb-3">In the Desktop UI</h3>
            <p class="text-neutral-600 dark:text-neutral-400">
              Use the model selector dropdown to switch between any configured provider and model.
            </p>
          </div>
        </Card>

        <Card class="mb-8">
          <div class="p-8">
            <h2 class="text-2xl font-bold mb-6">Multi-Tier Routing</h2>
            
            <p class="text-neutral-600 dark:text-neutral-400 mb-4">
              Automatically route queries to the best model based on complexity:
            </p>

            <div class="bg-neutral-900 text-neutral-100 p-4 rounded-lg font-mono text-sm overflow-x-auto mb-4">
              <code>
                routing:<br/>
                &nbsp;&nbsp;enabled: true<br/>
                &nbsp;&nbsp;mode: complexity  # or manual, cost<br/>
                &nbsp;&nbsp;<br/>
                &nbsp;&nbsp;# Define tiers<br/>
                &nbsp;&nbsp;tiers:<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;- name: fast<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;complexity_max: 3  # 0-10 scale<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;models:<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- ollama:phi3:latest<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- gpt-3.5-turbo<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;- name: balanced<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;complexity_max: 7<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;models:<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- ollama:llama3.2:latest<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- claude-3-haiku-20240307<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;- name: powerful<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;complexity_max: 10<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;models:<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- claude-3-5-sonnet-20241022<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- gpt-4
              </code>
            </div>

            <p class="text-sm text-neutral-600 dark:text-neutral-400">
              Simple questions → fast tier, complex reasoning → powerful tier. Saves money and time!
            </p>
          </div>
        </Card>

        <Card class="mb-8">
          <div class="p-8">
            <h2 class="text-2xl font-bold mb-6">Fallback Configuration</h2>
            
            <p class="text-neutral-600 dark:text-neutral-400 mb-4">
              Automatically try backup providers if the primary fails:
            </p>

            <div class="bg-neutral-900 text-neutral-100 p-4 rounded-lg font-mono text-sm overflow-x-auto">
              <code>
                fallback:<br/>
                &nbsp;&nbsp;enabled: true<br/>
                &nbsp;&nbsp;max_retries: 3<br/>
                &nbsp;&nbsp;<br/>
                &nbsp;&nbsp;# Fallback order for each provider<br/>
                &nbsp;&nbsp;chains:<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;openai:<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- anthropic:claude-3-5-sonnet-20241022<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- ollama:llama3.2:latest<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;anthropic:<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- openai:gpt-4<br/>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- ollama:llama3.2:latest
              </code>
            </div>
          </div>
        </Card>

        <Card class="mb-8">
          <div class="p-8">
            <h2 class="text-2xl font-bold mb-6">Getting API Keys</h2>
            
            <div class="space-y-4">
              <div class="border-l-4 border-brand-500 pl-4">
                <h4 class="font-bold mb-2">OpenAI</h4>
                <p class="text-sm text-neutral-600 dark:text-neutral-400">
                  1. Go to <a href="https://platform.openai.com/api-keys" class="text-brand-500 hover:underline">platform.openai.com/api-keys</a><br/>
                  2. Click "Create new secret key"<br/>
                  3. Copy the key (starts with <code class="bg-neutral-100 dark:bg-neutral-800 px-2 py-1 rounded">sk-</code>)
                </p>
              </div>

              <div class="border-l-4 border-brand-500 pl-4">
                <h4 class="font-bold mb-2">Anthropic</h4>
                <p class="text-sm text-neutral-600 dark:text-neutral-400">
                  1. Go to <a href="https://console.anthropic.com/settings/keys" class="text-brand-500 hover:underline">console.anthropic.com/settings/keys</a><br/>
                  2. Click "Create Key"<br/>
                  3. Copy the key (starts with <code class="bg-neutral-100 dark:bg-neutral-800 px-2 py-1 rounded">sk-ant-</code>)
                </p>
              </div>

              <div class="border-l-4 border-brand-500 pl-4">
                <h4 class="font-bold mb-2">Google Gemini</h4>
                <p class="text-sm text-neutral-600 dark:text-neutral-400">
                  1. Go to <a href="https://makersuite.google.com/app/apikey" class="text-brand-500 hover:underline">makersuite.google.com/app/apikey</a><br/>
                  2. Click "Create API Key"<br/>
                  3. Copy the generated key
                </p>
              </div>

              <div class="border-l-4 border-brand-500 pl-4">
                <h4 class="font-bold mb-2">Ollama</h4>
                <p class="text-sm text-neutral-600 dark:text-neutral-400">
                  No API key needed! Just install Ollama and pull models.<br/>
                  See the <a href="/docs/ollama" class="text-brand-500 hover:underline">Ollama Integration Guide</a> for setup.
                </p>
              </div>
            </div>
          </div>
        </Card>

        <Card class="mb-8">
          <div class="p-8">
            <h2 class="text-2xl font-bold mb-6">Model Recommendations</h2>
            
            <div class="grid md:grid-cols-2 gap-4">
              <div class="p-4 border border-neutral-200 dark:border-neutral-700 rounded-lg">
                <h4 class="font-bold mb-2">Best for Coding</h4>
                <ul class="text-sm text-neutral-600 dark:text-neutral-400 space-y-1">
                  <li>1. GPT-4 Turbo (OpenAI)</li>
                  <li>2. Claude 3.5 Sonnet (Anthropic)</li>
                  <li>3. Qwen2.5-Coder (Ollama)</li>
                </ul>
              </div>

              <div class="p-4 border border-neutral-200 dark:border-neutral-700 rounded-lg">
                <h4 class="font-bold mb-2">Best for Writing</h4>
                <ul class="text-sm text-neutral-600 dark:text-neutral-400 space-y-1">
                  <li>1. Claude 3 Opus (Anthropic)</li>
                  <li>2. Claude 3.5 Sonnet (Anthropic)</li>
                  <li>3. GPT-4 (OpenAI)</li>
                </ul>
              </div>

              <div class="p-4 border border-neutral-200 dark:border-neutral-700 rounded-lg">
                <h4 class="font-bold mb-2">Best for Speed</h4>
                <ul class="text-sm text-neutral-600 dark:text-neutral-400 space-y-1">
                  <li>1. GPT-3.5 Turbo (OpenAI)</li>
                  <li>2. Claude 3 Haiku (Anthropic)</li>
                  <li>3. Phi3 (Ollama)</li>
                </ul>
              </div>

              <div class="p-4 border border-neutral-200 dark:border-neutral-700 rounded-lg">
                <h4 class="font-bold mb-2">Best Value (Free)</h4>
                <ul class="text-sm text-neutral-600 dark:text-neutral-400 space-y-1">
                  <li>1. Llama 3.2 (Ollama)</li>
                  <li>2. Qwen2.5 (Ollama)</li>
                  <li>3. Mistral (Ollama)</li>
                </ul>
              </div>
            </div>
          </div>
        </Card>

        <Card>
          <div class="p-8">
            <h2 class="text-2xl font-bold mb-6">Usage Tips</h2>
            
            <ul class="space-y-3 text-neutral-600 dark:text-neutral-400">
              <li class="flex gap-3">
                <span class="text-brand-500 font-bold">→</span>
                <span><strong>Start with Ollama:</strong> Free, private, great for learning and experimentation</span>
              </li>
              <li class="flex gap-3">
                <span class="text-brand-500 font-bold">→</span>
                <span><strong>Add cloud for complexity:</strong> Use GPT-4 or Claude for hard problems</span>
              </li>
              <li class="flex gap-3">
                <span class="text-brand-500 font-bold">→</span>
                <span><strong>Enable multi-tier:</strong> Automatic model selection saves money</span>
              </li>
              <li class="flex gap-3">
                <span class="text-brand-500 font-bold">→</span>
                <span><strong>Set up fallback:</strong> Never get stuck when a provider is down</span>
              </li>
              <li class="flex gap-3">
                <span class="text-brand-500 font-bold">→</span>
                <span><strong>Monitor costs:</strong> Use <code class="bg-neutral-100 dark:bg-neutral-800 px-2 py-1 rounded">./openclaw stats</code> to see usage by provider</span>
              </li>
            </ul>
          </div>
        </Card>
      </div>
    </Section>
  </Container>
</PageLayout>
