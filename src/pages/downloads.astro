---
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/ui/layout/Container/Container.astro';
import Section from '@/components/ui/layout/Section/Section.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Button from '@/components/ui/form/Button/Button.astro';

const latestVersion = 'v2026.3.2-ce';
const releaseDate = 'March 2026';
const githubReleaseDownload = 'https://github.com/ssfdre38/openclaw-community-edition/releases/download/v2026.3.2-ce';
const githubReleaseUrl = 'https://github.com/ssfdre38/openclaw-community-edition/releases/tag/v2026.3.2-ce';
const githubReleasesUrl = 'https://github.com/ssfdre38/openclaw-community-edition/releases';
---

<PageLayout
  title="Downloads - OpenClaw CE"
  description="Download OpenClaw Community Edition and start building AI agents today"
>
  <Container>
    <Section>
      <div class="text-center max-w-3xl mx-auto mb-16">
        <Badge pill class="mb-4">Latest Release</Badge>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          Download <span class="text-brand-500">OpenClaw CE</span>
        </h1>
        <p class="text-lg text-neutral-600 dark:text-neutral-400">
          Get started with OpenClaw Community Edition. Free, open source, and ready for production.
        </p>
      </div>

      <!-- npm Package - Recommended -->
      <Card class="mb-8 border-emerald-500/30 bg-gradient-to-br from-emerald-500/10 to-green-500/10">
        <div class="p-8">
          <div class="flex items-center gap-3 mb-4">
            <div class="p-3 rounded-full bg-emerald-500 text-white">
              <Icon name="box" size="xl" />
            </div>
            <div>
              <Badge pill class="bg-emerald-500 text-white mb-2">Recommended</Badge>
              <h2 class="text-2xl font-bold">Install via npm (Easiest!)</h2>
              <p class="text-sm text-neutral-500">One command, works everywhere, automatic updates</p>
            </div>
          </div>
          
          <div class="grid md:grid-cols-2 gap-6 mb-4">
            <!-- npm Registry -->
            <div class="bg-white dark:bg-neutral-800 rounded-lg p-6 border-2 border-emerald-500/30">
              <div class="flex items-center gap-2 mb-3">
                <Icon name="npm" class="text-red-500" />
                <h3 class="font-bold">npm Registry</h3>
              </div>
              <div class="bg-neutral-900 text-neutral-100 p-3 rounded-lg font-mono text-xs mb-3">
                <code>npm install -g openclaw-ce</code>
              </div>
              <p class="text-xs text-neutral-500 mb-2">
                ✅ Simplest installation<br/>
                ✅ No GitHub account needed<br/>
                ✅ Auto-downloads right binaries for your OS
              </p>
              <Button 
                href="https://www.npmjs.com/package/openclaw-ce" 
                variant="outline" 
                size="sm" 
                class="w-full mt-2"
                target="_blank"
              >
                <Icon name="external-link" size="sm" />
                View on npm
              </Button>
            </div>

            <!-- GitHub Packages -->
            <div class="bg-white dark:bg-neutral-800 rounded-lg p-6 border border-neutral-200 dark:border-neutral-700">
              <div class="flex items-center gap-2 mb-3">
                <Icon name="github" class="text-neutral-700 dark:text-neutral-300" />
                <h3 class="font-bold">GitHub Packages</h3>
              </div>
              <div class="bg-neutral-900 text-neutral-100 p-3 rounded-lg font-mono text-xs mb-3">
                <div class="mb-2"># One-time setup:</div>
                <div class="mb-2">echo "@ssfdre38:registry=https://npm.pkg.github.com" >> ~/.npmrc</div>
                <div># Install:</div>
                <div>npm install -g @ssfdre38/openclaw-ce</div>
              </div>
              <Button 
                href="https://github.com/ssfdre38?tab=packages" 
                variant="outline" 
                size="sm" 
                class="w-full"
                target="_blank"
              >
                <Icon name="external-link" size="sm" />
                View on GitHub
              </Button>
            </div>
          </div>

          <div class="p-4 bg-emerald-500/10 border border-emerald-500/20 rounded-lg">
            <p class="text-sm text-neutral-700 dark:text-neutral-300">
              <strong>After installing:</strong> Run <code class="bg-neutral-800 px-2 py-1 rounded text-emerald-400">openclaw-ce gateway start</code> to launch!
            </p>
          </div>
        </div>
      </Card>

      <!-- Quick Start Guide -->
      <Card class="mb-12 border-brand-500/30 bg-gradient-to-br from-brand-500/5 to-purple-500/5">
        <div class="p-8">
          <div class="flex items-center gap-3 mb-6">
            <div class="p-3 rounded-full bg-brand-500 text-white">
              <Icon name="zap" size="xl" />
            </div>
            <h2 class="text-2xl font-bold">Other Installation Methods</h2>
          </div>
          
          <div class="grid md:grid-cols-3 gap-6">
            <!-- Quick Start -->
            <div class="bg-white dark:bg-neutral-800 rounded-lg p-6 border border-neutral-200 dark:border-neutral-700">
              <div class="flex items-center gap-2 mb-3">
                <Icon name="rocket" class="text-green-500" />
                <h3 class="font-bold text-green-600 dark:text-green-400">Pre-built Binary</h3>
              </div>
              <p class="text-sm text-neutral-600 dark:text-neutral-400 mb-3">
                Download a <strong>pre-built binary</strong> below. No Node.js install needed - just extract and run!
              </p>
              <p class="text-xs text-neutral-500">
                ✅ Best for: Offline installs, air-gapped systems
              </p>
            </div>

            <!-- Production -->
            <div class="bg-white dark:bg-neutral-800 rounded-lg p-6 border border-neutral-200 dark:border-neutral-700">
              <div class="flex items-center gap-2 mb-3">
                <Icon name="box" class="text-brand-500" />
                <h3 class="font-bold text-brand-600 dark:text-brand-400">Docker</h3>
              </div>
              <p class="text-sm text-neutral-600 dark:text-neutral-400 mb-3">
                Use <strong>Docker</strong> for easy deployment, updates, and isolation. Runs anywhere Docker runs.
              </p>
              <p class="text-xs text-neutral-500">
                ✅ Best for: Servers, cloud deployments, containers
              </p>
            </div>

            <!-- Developer -->
            <div class="bg-white dark:bg-neutral-800 rounded-lg p-6 border border-neutral-200 dark:border-neutral-700">
              <div class="flex items-center gap-2 mb-3">
                <Icon name="code" class="text-purple-500" />
                <h3 class="font-bold text-purple-600 dark:text-purple-400">Build from Source</h3>
              </div>
              <p class="text-sm text-neutral-600 dark:text-neutral-400 mb-3">
                Run the <strong>automated installer</strong> to build from source. Customize everything.
              </p>
              <p class="text-xs text-neutral-500">
                ✅ Best for: Developers, customization, contributions
              </p>
            </div>
          </div>

          <div class="mt-6 p-4 bg-blue-500/10 border border-blue-500/20 rounded-lg">
            <div class="flex items-start gap-3">
              <Icon name="info" class="text-blue-500 mt-1 flex-shrink-0" />
              <div class="text-sm text-neutral-700 dark:text-neutral-300">
                <strong>Add-ons:</strong> After installing, you can optionally add <strong>Ollama</strong> (run AI models locally on your machine) 
                or <strong>Image Generation</strong> (create images with Stable Diffusion). These are optional - OpenClaw works with cloud AI providers by default.
              </div>
            </div>
          </div>
        </div>
      </Card>

      <!-- Automated Installers -->
      <div class="mb-8">
        <h2 class="text-3xl font-bold mb-2">Automated Installers</h2>
        <p class="text-neutral-600 dark:text-neutral-400 mb-6">
          One-line command to install Node.js, clone, build, and set up OpenClaw. Best for developers who want full control.
        </p>
      </div>
      
      <div class="grid md:grid-cols-2 gap-6 mb-12">
        <!-- Windows PowerShell Installer -->
        <Card class="bg-gradient-to-br from-blue-500/5 to-blue-600/5 border-blue-500/20">
          <div class="p-8">
            <div class="flex items-center gap-3 mb-4">
              <div class="p-2 rounded-lg bg-blue-500 text-white">
                <Icon name="terminal" size="lg" />
              </div>
              <div>
                <h3 class="text-xl font-bold">Windows Installer</h3>
                <p class="text-sm text-neutral-500">Automated PowerShell setup</p>
              </div>
            </div>
            <div class="bg-neutral-900 text-neutral-100 p-4 rounded-lg font-mono text-xs overflow-x-auto mb-4">
              <code>irm https://raw.githubusercontent.com/ssfdre38/openclaw-community-edition/discord-fix/install.ps1 | iex</code>
            </div>
            <p class="text-sm text-neutral-600 dark:text-neutral-400 mb-3">
              Automatically installs:
            </p>
            <ul class="text-xs space-y-1 text-neutral-500 mb-4">
              <li>✓ OpenClaw CE to ~/.openclaw</li>
              <li>✓ Dependencies (Git, Node.js 18+, pnpm)</li>
              <li>✓ Optional Ollama CE integration</li>
            </ul>
            <Button 
              href="https://raw.githubusercontent.com/ssfdre38/openclaw-community-edition/discord-fix/install.ps1" 
              variant="outline" 
              size="sm" 
              class="w-full"
            >
              <Icon name="download" size="sm" />
              Download Script
            </Button>
          </div>
        </Card>

        <!-- Linux/macOS Bash Installer -->
        <Card class="bg-gradient-to-br from-green-500/5 to-green-600/5 border-green-500/20">
          <div class="p-8">
            <div class="flex items-center gap-3 mb-4">
              <div class="p-2 rounded-lg bg-green-500 text-white">
                <Icon name="terminal" size="lg" />
              </div>
              <div>
                <h3 class="text-xl font-bold">Linux/macOS Installer</h3>
                <p class="text-sm text-neutral-500">Automated Bash setup</p>
              </div>
            </div>
            <div class="bg-neutral-900 text-neutral-100 p-4 rounded-lg font-mono text-xs overflow-x-auto mb-4">
              <code>curl -fsSL https://raw.githubusercontent.com/ssfdre38/openclaw-community-edition/discord-fix/install.sh | bash</code>
            </div>
            <p class="text-sm text-neutral-600 dark:text-neutral-400 mb-3">
              Automatically installs:
            </p>
            <ul class="text-xs space-y-1 text-neutral-500 mb-3">
              <li>✓ OpenClaw CE to ~/.openclaw</li>
              <li>✓ Dependencies (Git, Node.js 18+, pnpm)</li>
              <li>✓ Optional Ollama CE integration</li>
            </ul>
            <p class="text-xs text-neutral-600 dark:text-neutral-400 mb-4">
              After install: <code class="bg-neutral-800 px-1 rounded">openclaw onboard</code>
            </p>
            <p class="text-xs text-neutral-600 dark:text-neutral-400 mb-4">
              After install: <code class="bg-neutral-800 px-1 rounded">openclaw onboard</code>
            </p>
            <Button 
              href="https://raw.githubusercontent.com/ssfdre38/openclaw-community-edition/discord-fix/install.sh"
              variant="outline" 
              size="sm" 
              class="w-full"
            >
              <Icon name="download" size="sm" />
              Download Script
            </Button>
          </div>
        </Card>
      </div>

      <!-- Optional Add-ons -->
      <div class="mt-16 mb-8">
        <h2 class="text-3xl font-bold text-center mb-4">Optional Add-ons</h2>
        <p class="text-center text-neutral-600 dark:text-neutral-400 mb-2">
          Extend OpenClaw CE with local AI models and image generation
        </p>
        <p class="text-center text-sm text-neutral-500 dark:text-neutral-500">
          <strong>Note:</strong> OpenClaw works with cloud AI providers (OpenAI, Anthropic, Google) by default. These add-ons let you run AI locally for privacy/cost savings.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 mb-12">
        <!-- Ollama CE -->
        <Card class="bg-gradient-to-br from-orange-500/5 to-orange-600/5 border-orange-500/20">
          <div class="p-8">
            <div class="flex items-start gap-4 mb-4">
              <div class="p-3 rounded-lg bg-orange-500 text-white">
                <Icon name="robot" size="xl" />
              </div>
              <div class="flex-1">
                <h3 class="text-2xl font-bold mb-2">Ollama Community Edition</h3>
                <p class="text-neutral-600 dark:text-neutral-400 mb-4">
                  Run AI models locally without API keys. Supports LLaMA, CodeLLaMA, and more.
                </p>
              </div>
            </div>
            <div class="bg-neutral-900 text-neutral-100 p-4 rounded-lg font-mono text-sm overflow-x-auto mb-4">
              <code># Windows<br/>.\scripts\setup-ollama-ce.ps1<br/><br/># Linux/macOS<br/>bash scripts/setup-ollama-ce.sh</code>
            </div>
            <p class="text-sm text-neutral-500 mb-3">
              Installs to ~/.ollama-ce and builds from source with Go
            </p>
            <div class="grid grid-cols-2 gap-2">
              <Button 
                href="https://raw.githubusercontent.com/ssfdre38/openclaw-community-edition/discord-fix/scripts/setup-ollama-ce.ps1" 
                variant="outline"
                size="sm"
              >
                <Icon name="download" size="sm" />
                Windows
              </Button>
              <Button 
                href="https://raw.githubusercontent.com/ssfdre38/openclaw-community-edition/discord-fix/scripts/setup-ollama-ce.sh" 
                variant="outline"
                size="sm"
              >
                <Icon name="download" size="sm" />
                Linux/macOS
              </Button>
            </div>
          </div>
        </Card>

        <!-- Image Generation -->
        <Card class="bg-gradient-to-br from-purple-500/5 to-purple-600/5 border-purple-500/20">
          <div class="p-8">
            <div class="flex items-start gap-4 mb-4">
              <div class="p-3 rounded-lg bg-purple-500 text-white">
                <Icon name="image" size="xl" />
              </div>
              <div class="flex-1">
                <h3 class="text-2xl font-bold mb-2">Image Generation</h3>
                <p class="text-neutral-600 dark:text-neutral-400 mb-4">
                  Local Stable Diffusion & SDXL for AI image generation (Windows only).
                </p>
              </div>
            </div>
            <div class="bg-neutral-900 text-neutral-100 p-4 rounded-lg font-mono text-sm overflow-x-auto mb-4">
              <code>.\scripts\setup-image-generation.ps1</code>
            </div>
            <p class="text-sm text-neutral-500 mb-3">
              Sets up SD 1.5 (fast, 512x512) + SDXL (quality, 1024x1024) with web UI
            </p>
            <Button 
              href="https://raw.githubusercontent.com/ssfdre38/openclaw-community-edition/discord-fix/scripts/setup-image-generation.ps1" 
              variant="outline"
            >
              <Icon name="download" size="sm" />
              Download Script
            </Button>
          </div>
        </Card>
      </div>

      <!-- Pre-built Binaries Section -->
      <div class="mt-16 mb-8">
        <h2 class="text-3xl font-bold text-center mb-4">Pre-built Binaries</h2>
        <p class="text-center text-neutral-600 dark:text-neutral-400 mb-2">
          Standalone executables with Node.js bundled - just download and run!
        </p>
        <p class="text-center text-sm text-neutral-500 dark:text-neutral-500">
          Perfect for quick evaluation - no installation, no build tools, no Node.js required. Extract and execute.
        </p>
      </div>

      <!-- Download Options -->
      <div class="grid md:grid-cols-3 gap-6 mb-12">
        <!-- Windows -->
        <Card class="text-center hover:shadow-lg transition-shadow">
          <div class="p-6">
            <div class="inline-flex p-4 rounded-full bg-blue-500/10 text-blue-500 mb-4">
              <Icon name="monitor" size="xl" />
            </div>
            <h3 class="text-xl font-bold mb-2">Windows</h3>
            <p class="text-neutral-600 dark:text-neutral-400 mb-4">
              Windows 10/11 (x64)
            </p>
            <Badge class="mb-4">{latestVersion}</Badge>
            <div class="space-y-2">
              <Button href="{githubReleaseDownload}/openclaw-2026.3.2-ce-windows-x64.zip" class="w-full">
                <Icon name="download" size="sm" />
                Download ZIP (20 MB)
              </Button>
              <p class="text-xs text-neutral-500 dark:text-neutral-600">
                No Node.js required • Standalone executable
              </p>
            </div>
          </div>
        </Card>

        <!-- macOS -->
        <Card class="text-center hover:shadow-lg transition-shadow">
          <div class="p-6">
            <div class="inline-flex p-4 rounded-full bg-neutral-500/10 text-neutral-500 mb-4">
              <Icon name="apple" size="xl" />
            </div>
            <h3 class="text-xl font-bold mb-2">macOS</h3>
            <p class="text-neutral-600 dark:text-neutral-400 mb-4">
              macOS 11+ (Intel & Apple Silicon)
            </p>
            <Badge class="mb-4">{latestVersion}</Badge>
            <div class="space-y-2">
              <Button href="{githubReleaseDownload}/openclaw-2026.3.2-ce-macos-x64.zip" class="w-full">
                <Icon name="download" size="sm" />
                Download ZIP (23 MB)
              </Button>
              <p class="text-xs text-neutral-500 dark:text-neutral-600">
                No Node.js required • Intel Macs
              </p>
            </div>
          </div>
        </Card>

        <!-- Linux -->
        <Card class="text-center hover:shadow-lg transition-shadow">
          <div class="p-6">
            <div class="inline-flex p-4 rounded-full bg-orange-500/10 text-orange-500 mb-4">
              <Icon name="terminal" size="xl" />
            </div>
            <h3 class="text-xl font-bold mb-2">Linux</h3>
            <p class="text-neutral-600 dark:text-neutral-400 mb-4">
              Ubuntu, Debian, Fedora, Arch, etc.
            </p>
            <Badge class="mb-4">{latestVersion}</Badge>
            <div class="space-y-2">
              <Button href="{githubReleaseDownload}/openclaw-2026.3.2-ce-linux-x64.zip" class="w-full">
                <Icon name="download" size="sm" />
                Download ZIP (26 MB)
              </Button>
              <p class="text-xs text-neutral-500 dark:text-neutral-600">
                No Node.js required • x86_64
              </p>
            </div>
          </div>
        </Card>
      </div>

      <!-- View All Releases -->
      <div class="text-center mb-16">
        <Button href="{githubReleasesUrl}" variant="outline">
          <Icon name="github" size="sm" />
          View All Releases on GitHub
        </Button>
      </div>

      <!-- Docker -->
      <Card class="mb-12">
        <div class="p-8">
          <div class="flex items-start gap-4">
            <div class="p-3 rounded-lg bg-brand-500/10 text-brand-500">
              <Icon name="box" size="xl" />
            </div>
            <div class="flex-1">
              <h3 class="text-2xl font-bold mb-2">Docker</h3>
              <p class="text-neutral-600 dark:text-neutral-400 mb-4">
                Run OpenClaw CE in a container for easy deployment and isolation.
              </p>
              <div class="bg-neutral-900 text-neutral-100 p-4 rounded-lg font-mono text-sm overflow-x-auto mb-4">
                <code># Pull the image<br/>docker pull ssfdre38/openclawce:latest<br/><br/># Run with docker run<br/>docker run -d -p 18789:18789 --name openclaw ssfdre38/openclawce:latest<br/><br/># Or use docker-compose<br/>wget https://raw.githubusercontent.com/ssfdre38/openclaw-community-edition/discord-fix/docker-compose.yml<br/>docker-compose up -d</code>
              </div>
              <div class="flex gap-2">
                <Button href="https://hub.docker.com/r/ssfdre38/openclawce" target="_blank" variant="outline">
                  <Icon name="box" size="sm" />
                  Docker Hub
                </Button>
                <Button href="https://raw.githubusercontent.com/ssfdre38/openclaw-community-edition/discord-fix/docker-compose.yml" variant="outline">
                  <Icon name="download" size="sm" />
                  docker-compose.yml
                </Button>
              </div>
            </div>
          </div>
        </div>
      </Card>

      <!-- Source Code -->
      <Card class="mb-12 border-2 border-brand-500">
        <div class="p-8">
          <div class="flex items-start gap-4">
            <div class="p-3 rounded-lg bg-brand-500 text-white">
              <Icon name="github" size="xl" />
            </div>
            <div class="flex-1">
              <h3 class="text-2xl font-bold mb-2">Build from Source</h3>
              <p class="text-neutral-600 dark:text-neutral-400 mb-4">
                Clone the repository and build OpenClaw CE yourself. Perfect for contributors and customization.
              </p>
              <div class="bg-neutral-900 text-neutral-100 p-4 rounded-lg font-mono text-sm overflow-x-auto mb-4">
                <code>git clone -b discord-fix https://github.com/ssfdre38/openclaw-community-edition.git</code><br/>
                <code>cd openclaw-community-edition</code><br/>
                <code>npm install</code>
              </div>
              <Button href="https://github.com/ssfdre38/openclaw-community-edition" target="_blank" variant="outline">
                <Icon name="github" size="sm" />
                View on GitHub
              </Button>
            </div>
          </div>
        </div>
      </Card>

      <!-- System Requirements -->
      <Card>
        <div class="p-8">
          <h3 class="text-2xl font-bold mb-6 flex items-center gap-2">
            <Icon name="info" size="lg" />
            System Requirements
          </h3>
          <div class="grid md:grid-cols-2 gap-8">
            <div>
              <h4 class="font-semibold mb-3">Minimum Requirements</h4>
              <ul class="space-y-2 text-neutral-600 dark:text-neutral-400">
                <li class="flex items-start gap-2">
                  <Icon name="check" size="sm" class="text-green-500 mt-1" />
                  <span>Node.js 18+ (with npm/pnpm)</span>
                </li>
                <li class="flex items-start gap-2">
                  <Icon name="check" size="sm" class="text-green-500 mt-1" />
                  <span>4GB RAM</span>
                </li>
                <li class="flex items-start gap-2">
                  <Icon name="check" size="sm" class="text-green-500 mt-1" />
                  <span>1GB disk space (more for AI models)</span>
                </li>
                <li class="flex items-start gap-2">
                  <Icon name="check" size="sm" class="text-green-500 mt-1" />
                  <span>Internet connection (for cloud AI providers)</span>
                </li>
              </ul>
            </div>
            <div>
              <h4 class="font-semibold mb-3">Recommended</h4>
              <ul class="space-y-2 text-neutral-600 dark:text-neutral-400">
                <li class="flex items-start gap-2">
                  <Icon name="check" size="sm" class="text-brand-500 mt-1" />
                  <span>8GB+ RAM (for local models)</span>
                </li>
                <li class="flex items-start gap-2">
                  <Icon name="check" size="sm" class="text-brand-500 mt-1" />
                  <span>SSD storage</span>
                </li>
                <li class="flex items-start gap-2">
                  <Icon name="check" size="sm" class="text-brand-500 mt-1" />
                  <span>16GB+ RAM for image generation</span>
                </li>
                <li class="flex items-start gap-2">
                  <Icon name="check" size="sm" class="text-brand-500 mt-1" />
                  <span>GPU for fast image generation (optional)</span>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </Card>

      <!-- MCP Servers -->
      <Card class="mt-16 border-purple-500/30 bg-gradient-to-br from-purple-500/5 to-brand-500/5">
        <div class="p-8">
          <div class="flex items-center gap-3 mb-6">
            <div class="p-3 rounded-full bg-purple-500 text-white">
              <Icon name="puzzle" size="xl" />
            </div>
            <div>
              <h2 class="text-2xl font-bold">Custom MCP Servers</h2>
              <p class="text-sm text-neutral-600 dark:text-neutral-400">Extend OpenClaw with community-built integrations</p>
            </div>
          </div>

