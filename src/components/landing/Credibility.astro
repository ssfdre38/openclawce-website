---
import Icon from '@/components/ui/primitives/Icon/Icon.astro';

const features = [
  { feature: 'Multi-Provider', desc: 'OpenAI, Claude, Gemini, Ollama' },
  { feature: 'MCP Servers', desc: 'GitHub, filesystem, custom tools' },
  { feature: 'Browser Relay', desc: 'Real-time web access' },
  { feature: 'Image Generation', desc: 'Stable Diffusion + SDXL' },
  { feature: 'Smart Routing', desc: 'Complexity-based model selection' },
];

const stats = [
  { value: '1', label: 'config file' },
  { value: '4+', label: 'AI providers' },
  { value: '100%', label: 'open source' },
];
---

<section id="architecture" class="invert-section bg-background py-[var(--space-section)]">
  <div class="mx-auto grid max-w-6xl grid-cols-1 items-center gap-[var(--space-section-gap)] px-6 lg:grid-cols-2 lg:gap-[var(--space-section-gap)]">
    <!-- Left Column - Content -->
    <div>
      <!-- Badge -->
      <div
        class="text-brand-500 mb-4 flex items-center gap-2 text-sm font-bold tracking-wide uppercase"
      >
        <Icon name="settings" size="sm" />
        <span>Simple Configuration</span>
      </div>

      <h2 class="font-display mb-[var(--space-heading-gap)] text-3xl font-bold text-balance md:text-4xl">
        One YAML file. <span class="text-brand-500">Unlimited possibilities.</span>
      </h2>

      <div class="text-foreground-secondary space-y-4 text-lg leading-relaxed">
        <p>
          OpenClaw CE uses a single configuration file to manage everything - AI providers, tools, features, and routing.
        </p>
        <p>
          Want to add Ollama for free local AI? Add a few lines to <code class="font-mono text-base text-cyan-400">config.yaml</code>. Need GitHub integration? Configure an MCP server. Image generation? Enable it with one setting.
        </p>
        <p class="text-foreground-muted">
          No complicated setup. No multiple config files. Just clean, readable YAML that does what it says.
        </p>
      </div>

      <!-- Stats -->
      <div class="border-border mt-[var(--space-stack-lg)] grid grid-cols-3 gap-[var(--space-stack-lg)] border-t pt-[var(--space-stack-lg)]">
        {
          stats.map((stat) => (
            <div>
              <div class="font-display text-foreground text-3xl font-bold">{stat.value}</div>
              <div class="text-foreground-muted text-sm">{stat.label}</div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Right Column - Terminal Card -->
    <div class="relative">
      <div
        class="bg-card border-border overflow-hidden rounded-lg border shadow-xl"
      >
        <!-- Terminal Header -->
        <div
          class="bg-secondary border-border flex items-center gap-2 border-b px-4 py-3"
        >
          <div class="flex gap-2">
            <span class="h-3 w-3 rounded-full" style="background-color: var(--error);"></span>
            <span class="h-3 w-3 rounded-full" style="background-color: var(--warning);"></span>
            <span class="h-3 w-3 rounded-full" style="background-color: var(--success);"></span>
          </div>
          <span class="text-foreground-muted ml-2 font-mono text-xs">~/.openclaw/config.yaml</span>
        </div>

        <!-- Terminal Body -->
        <div class="p-5 font-mono text-sm leading-relaxed">
          <!-- Comment -->
          <div class="text-foreground-muted mb-3"># Simple, powerful configuration</div>

          <!-- Config snippet -->
          <div class="space-y-2">
            <div><span class="text-cyan-400">providers</span><span class="text-foreground">:</span></div>
            {
              features.map((item) => (
                <div class="flex items-start gap-3 pl-4">
                  <span class="shrink-0 text-green-400">✓</span>
                  <div>
                    <span class="font-semibold text-foreground">{item.feature}</span>
                    <span class="text-foreground-muted text-xs block">{item.desc}</span>
                  </div>
                </div>
              ))
            }
          </div>

          <!-- Output -->
          <div class="border-border mt-6 border-t pt-4">
            <div class="flex items-center gap-2">
              <span class="text-green-400">✓</span>
              <span class="text-foreground">All features configured!</span>
            </div>
            <div class="text-foreground-muted mt-1 pl-5">./openclaw chat</div>
          </div>
        </div>
      </div>

      <!-- Decorative glow -->
      <div
        class="bg-brand-500/10 pointer-events-none absolute top-0 right-0 h-32 w-32 rounded-full blur-3xl"
      >
      </div>
    </div>
  </div>
</section>
